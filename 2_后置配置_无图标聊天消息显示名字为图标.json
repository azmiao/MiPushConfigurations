{
  "version": "0.1.0",
  "configs": {
    "$-无图标聊天消息显示名字为图标": [
      {
        "match": {
          "metaInfo": {
            "extra": {
              "__mi_push_conversation_sender": "(\\[[^\\]]+])?(?<sender>[a-zA-Z]{3,}|[一-龥]+)"
            }
          }
        },
        "replace": {
          "metaInfo": {
            "extra": {
              "__mi_push_text_icon": "${sender}"
            }
          }
        },
        "stop": false
      }
    ]
  }
}