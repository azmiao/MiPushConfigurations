{
  "version": "0.1.0",
  "configs": {
    "QQ-消息按群分组": [
      {
        "metaInfo": {
          "extra": {
            "intent_uri": "^(?!.*S\\.groupuin=).*S\\.groupcode=(?<id>\\d+)"
          }
        },
        "newMetaInfo": {
          "extra": {
            "notification_group": "${id}"
          }
        },
        "stop": false
      }
    ]
  }
}